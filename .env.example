# J TRADERS - Environment Configuration

# ============================================
# STRIPE PAYMENT CONFIGURATION
# ============================================

# Get your keys from: https://dashboard.stripe.com/apikeys

# Publishable Key (Safe to use in frontend)
# Replace with your actual Stripe Publishable Key
STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_PUBLISHABLE_KEY_HERE

# Secret Key (Keep private - backend only)
# Replace with your actual Stripe Secret Key
STRIPE_SECRET_KEY=sk_test_YOUR_SECRET_KEY_HERE

# Webhook Secret (for handling Stripe events)
# Get from: Dashboard → Developers → Webhooks
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET_HERE

# ============================================
# PAYMENT SETTINGS
# ============================================

# Course pricing (in USD)
COURSE_FOUNDATION_PRICE=297
COURSE_ADVANCED_PRICE=797
COURSE_ELITE_PRICE=1497
MENTORSHIP_PRICE=2997

# Course access duration (in months)
COURSE_ACCESS_MONTHS=6

# Currency (for Stripe)
CURRENCY=usd

# ============================================
# ADMIN CONFIGURATION
# ============================================

# Admin authentication token (generate a strong random string)
ADMIN_TOKEN=your_secure_admin_token_here_min_32_chars_strong

# Admin email for notifications
ADMIN_EMAIL=admin@jtraders.com

# ============================================
# SERVER CONFIGURATION
# ============================================

# Server port
PORT=5000

# Environment (development, staging, production)
NODE_ENV=development

# Server URL
SERVER_URL=http://localhost:5000

# Frontend URL
FRONTEND_URL=http://localhost:3000

# ============================================
# DATABASE CONFIGURATION
# ============================================

# Choose your database type: mysql, postgresql, mongodb
DATABASE_TYPE=postgresql

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=jtraders_user
DB_PASSWORD=secure_password_here
DB_NAME=jtraders

# MongoDB (if using MongoDB)
MONGODB_URI=mongodb://localhost:27017/jtraders

# MySQL
DB_MYSQL_HOST=localhost
DB_MYSQL_USER=jtraders_user
DB_MYSQL_PASSWORD=secure_password_here
DB_MYSQL_DATABASE=jtraders

# ============================================
# EMAIL CONFIGURATION
# ============================================

# Email service provider: sendgrid, mailgun, gmail, aws_ses
EMAIL_SERVICE=sendgrid

# SendGrid
SENDGRID_API_KEY=your_sendgrid_api_key_here
EMAIL_FROM=noreply@jtraders.com

# Mailgun
MAILGUN_API_KEY=your_mailgun_api_key_here
MAILGUN_DOMAIN=mg.jtraders.com

# Gmail (SMTP)
GMAIL_USER=your-email@gmail.com
GMAIL_PASS=your-app-specific-password

# AWS SES
AWS_SES_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key

# ============================================
# SECURITY CONFIGURATION
# ============================================

# JWT Secret for authentication tokens
JWT_SECRET=your_jwt_secret_key_here_min_32_chars

# JWT expiration time
JWT_EXPIRATION=7d

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,https://jtraders.com

# Rate limiting
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX_REQUESTS=100

# ============================================
# LOG CONFIGURATION
# ============================================

# Log level: error, warn, info, debug
LOG_LEVEL=info

# Log file path
LOG_FILE=./logs/app.log

# ============================================
# FEATURES
# ============================================

# Enable/disable features
ENABLE_EMAIL_NOTIFICATIONS=true
ENABLE_SMS_NOTIFICATIONS=false
ENABLE_REFUNDS=true
ENABLE_COURSE_RENEWAL=true
ENABLE_AFFILIATE_PROGRAM=false

# ============================================
# SMS CONFIGURATION (Optional)
# ============================================

# Twilio
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# ============================================
# ANALYTICS & MONITORING
# ============================================

# Google Analytics
GOOGLE_ANALYTICS_ID=UA-XXXXXXXXX-X

# Sentry (Error tracking)
SENTRY_DSN=https://key@sentry.io/project-id

# ============================================
# SOCIAL MEDIA & MARKETING
# ============================================

# Facebook Pixel
FACEBOOK_PIXEL_ID=123456789

# LinkedIn
LINKEDIN_CONVERSION_ID=1234567

# ============================================
# INSTRUCTIONS FOR SETUP
# ============================================

# 1. CREATE A NEW .env FILE
#    - Save this as .env in the project root
#    - Never commit .env to version control

# 2. GET YOUR STRIPE KEYS
#    - Go to https://dashboard.stripe.com/apikeys
#    - Test mode: Copy Test Publishable & Secret Keys
#    - Replace the placeholder values above

# 3. SETUP PAYMENT WEBHOOK
#    - In Stripe Dashboard: Developers → Webhooks
#    - Click "Add endpoint"
#    - URL: https://yourdomain.com/api/webhook
#    - Events: payment_intent.succeeded, payment_intent.payment_failed
#    - Copy the Signing Secret to STRIPE_WEBHOOK_SECRET

# 4. GENERATE SECURE TOKENS
#    - ADMIN_TOKEN: Use 'openssl rand -hex 16' or a password manager
#    - JWT_SECRET: Use 'openssl rand -hex 32'

# 5. SETUP DATABASE
#    - Create database: CREATE DATABASE jtraders;
#    - Create user: CREATE USER 'jtraders_user' IDENTIFIED BY 'password';
#    - Grant privileges: GRANT ALL ON jtraders.* TO 'jtraders_user';

# 6. SETUP EMAIL SERVICE
#    - For SendGrid: Get API key from https://app.sendgrid.com/settings/api_keys
#    - For Gmail: Enable 2FA and generate app-specific password
#    - For Mailgun: Get API key from https://app.mailgun.com/app/account/security/api_keys

# 7. TEST YOUR CONFIGURATION
#    - Start server: npm start
#    - Check console for connection messages
#    - Use test Stripe card: 4242 4242 4242 4242

# ============================================
# SECURITY NOTES
# ============================================

# IMPORTANT: Never share your .env file or secret keys!
# Keep STRIPE_SECRET_KEY and JWT_SECRET private
# Rotate security tokens regularly
# Use strong, unique passwords
# Enable 2FA on all important accounts

# FOR PRODUCTION:
# - Use environment variables provided by your hosting platform
# - Enable HTTPS only
# - Use production Stripe keys (pk_live_, sk_live_)
# - Set NODE_ENV=production
# - Implement rate limiting
# - Enable CORS restrictions
# - Setup SSL certificates
# - Monitor logs and errors
# - Regular security audits

# ============================================
# USEFUL STRIPE TEST CARDS
# ============================================

# Success: 4242 4242 4242 4242
# Decline: 4000 0000 0000 0002
# Requires authentication: 4000 2500 0000 3010
# Insufficient funds: 4000 0000 0000 9995
# Lost card: 4000 0000 0000 9979

# Use any future expiration date (e.g., 12/25)
# Use any 3-digit CVC (e.g., 123)
